@using GoldenBarbers.Client.Services.Public;
@using System.Threading.Tasks
@using Shared.DTOs.Public
@using GoldenBarbers.Client.Helpers

@inject BarberApiService BarberService
@inject OfferingApiService OfferingService
@inject TimeslotApiService TimeslotService
@inject AppointmentApiService AppointmentsService
@inject ScrollService ScrollService
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> L

@inject NavigationManager Navigation

@page "/book-appointment"

<div class="booking-container">
    <h2 class="booking-text">@L["Appointment_BookAppointment"]</h2>
    <br />
</div>


<EditForm Model="appointment" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />

    <div class="booking-container">
        <label class="booking-text">@L["Appointment_SelectService"] </label>
        <br />

        <div class="selection">

            @if (offerings != null)
            {
                foreach (var o in offerings)
                {
                    @if (_selectedOfferingId == o.Id)
                    {
                        <div>
                            <div class="selected" @onclick="() => SelectOffering(o.Id)">
                                <img src="@o.Icon" alt="Offering" />
                                <br />
                                <p>@o.Name</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div>
                            <div class="selection-item" @onclick="() => SelectOffering(o.Id)">
                                <img src="@o.Icon" alt="Offering" />
                                <br />
                                <p>@o.Name</p>
                            </div>
                        </div>
                    }
                }
            }
        </div>

        <br /><br />

        <label class="booking-text">@L["Appointment_SelectBarber"] </label>
        <br />

        <div class="selection">

            @if (barbers != null)
            {
                @foreach (var b in barbers)
                {
                    @if (_selectedBarberId == b.Id)
                    {
                        <div>
                            <div class="selected" @onclick="() => SelectBarber(b.Id)">

                                <img src="@b.Portrait" alt="Barber" />
                                <p>@b.Name</p>
                                <p>@b.PositionName</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div>
                            <div class="selection-item" @onclick="() => SelectBarber(b.Id)">

                                <img src="@b.Portrait" alt="Barber" />
                                <p>@b.Name</p>
                                <p>@b.PositionName</p>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
    <br />
    <br />

    @if (_selectedBarberId != Guid.Empty && _selectedOfferingId != Guid.Empty)
    {
        <div class="booking-container" id="calendar-table">
            <div class="booking-text">
                <button type="button" disabled="@IsDisabled" @onclick="PrevWeek">⬅ @L["Appointment_PrevWeek"]</button>
                <span>@weekStart.ToString("MMM dd, yyyy") - @weekEnd.ToString("MMM dd, yyyy")</span>
                <button type="button" @onclick="NextWeek">@L["Appointment_NextWeek"] ➡</button>
            </div>
        </div>

        @if (timeslots == null || barbers == null)
        {
            <p class="custom-loader">@L["Appointment_LoadingCalendar"]</p>
        }
        else
        {
            <div class="booking-container">
                <table class="calendar-table">
                    <thead>
                        <tr>
                            <th>@L["Appointment_TimeHeading"]</th>
                            @foreach (var day in Enumerable.Range(0, 6))
                            {
                                var currentDay = weekStart.AddDays(day);
                                <th>@currentDay.ToString("ddd dd")</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var time in timeRanges)
                        {
                            <tr>
                                <td>@time.ToString("HH:mm")</td>

                                @foreach (var day in Enumerable.Range(0, 6))
                                {
                                    var currentDate = weekStart.AddDays(day);
                                    var currentDateTime = DateTime.SpecifyKind(currentDate.Add(time.TimeOfDay), DateTimeKind.Utc);

                                    var nowInHelsinki = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, _helsinkiZone);

                                    var daySlots = timeslots
                                    .Where(s =>
                                    s.Start.Date == currentDate &&
                                    s.Start.TimeOfDay == time.TimeOfDay &&
                                    s.BarberId == appointment.BarberId &&
                                    s.IsAvailable)
                                    .ToList();

                                    <td>
                                        
                                        @if (nowInHelsinki > currentDateTime)
                                        {
                                            <span class="unavailable">-</span>
                                        }
                                        else if (!daySlots.Any())
                                        {
                                            <span class="unavailable">@L["Appointment_Reserved"]</span>
                                        }

                                        else
                                        {
                                            @foreach (var slot in daySlots)
                                            {
                                                <button class="timeslot" type="button"
                                                        @onclick="() => SelectSlot(slot)">

                                                    @(selectedSlot?.Id == slot.Id ? L["Appointment_Selected"] : L["Appointment_Select"])
                                                </button>
                                                <br />
                                            }
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (selectedSlot != null)
        {
            <div style="margin-top: 100px;" class="booking-container" id="booking-summary">
                <div class="booking-summary">
                    <h3>@L["Appointment_AppointmentInformation"]</h3>
                    <br />

                    @if (barbers != null)
                    {
                        <p>@L["Appointment_BarberPreview"] @barbers.First(b => b.Id == selectedSlot.BarberId).Name</p>

                    }

                    @if (offerings != null && barbers != null && _selectedBarberId != Guid.Empty && _selectedOfferingId != Guid.Empty)
                    {
                        var selectedBarber = barbers.FirstOrDefault(b => b.Id == _selectedBarberId);
                        var selectedOffering = offerings.FirstOrDefault(o => o.Id == _selectedOfferingId);

                        int pricePreview = (selectedBarber == null || selectedOffering == null)
                        ? 0
                        : PricingService.CalculatePrice(selectedOffering, selectedBarber.PositionId);

                        <p>@L["Appointment_PricePreview"] @(appointment.FinalPrice > 0 ? appointment.FinalPrice : pricePreview) €</p>
                    }


                    @if (offerings != null && appointment.OfferingId != Guid.Empty)
                    {
                        var selectedOffering = offerings.FirstOrDefault(o => o.Id == appointment.OfferingId);
                        <p>@L["Appointment_ServicePreview"] @selectedOffering?.Name</p>
                    }

                    <p>@L["Appointment_TimePreview"] @selectedSlot.Start.ToString($"dd.MM.yyyy, HH:mm")</p>
                </div>
            </div>
        }
        <br />

        @if (selectedSlot != null)
        {
            <div class="booking-container">
                <div class="booking-text">
                    <h3>@L["Appointment_ContactInfo"] </h3>
                    <br />
                    <p>@L["Appointment_ProvideContactInfo1"] <br />@L["Appointment_ProvideContactInfo2"]</p>

                    <br />
                    <label>
                        @L["Appointment_CustomerName"]
                        <InputText @bind-Value="appointment.CustomerName"></InputText>
                        <ValidationMessage For="@(() => appointment.CustomerName)" />
                    </label>
                    <br /><br />
                    <label>
                        @L["Appointment_CustomerEmail"]
                        <InputText @bind-Value="appointment.CustomerEmail"></InputText>
                        <ValidationMessage For="@(() => appointment.CustomerEmail)" />

                    </label>
                    <br /><br /><br />
                    <button class="btn btn-light" type="submit" disabled=@IsSubmitting>@L["Appointment_ConfirmBookingButton"]</button>
                </div>
            </div>
        }
    }
</EditForm>

    @code {

    // TODO: Exctract calendar to separate component
    AppointmentDto appointment = new();

    private List<OfferingDto>? offerings;
    private List<BarberDto>? barbers;
    private List<TimeslotDto>? timeslots;
    private TimeslotDto? selectedSlot;

    private bool IsSubmitting { get; set; } = false;
    private bool IsDisabled { get; set; } = false;

    private static readonly TimeZoneInfo _helsinkiZone =
    TimeZoneInfo.FindSystemTimeZoneById("Europe/Helsinki");

    private Guid _selectedBarberId;

    private Guid SelectedBarberId
    {
        get => _selectedBarberId;
        set
        {

            if (_selectedBarberId != value)
            {
                _selectedBarberId = value;
                appointment.BarberId = value;
                selectedSlot = null;
            }
        }
    }

    private Guid _selectedOfferingId;

    private Guid SelectedOfferingId
    {
        get => _selectedOfferingId;
        set
        {

            if (_selectedOfferingId != value)
            {
                _selectedOfferingId = value;
                appointment.OfferingId = value;
                selectedSlot = null;
            }
        }
    }

    private DateTime weekStart = DateTime.Today.StartOfWeek(DayOfWeek.Monday);
    private DateTime weekEnd => weekStart.AddDays(7);

    private List<DateTime> timeRanges = new();


    protected override async Task OnInitializedAsync()
    {
        offerings = await OfferingService.GetAllOfferingsAsync();
        barbers = await BarberService.GetBarbersAsync();

        GenerateTimeRanges();
        await LoadSlots();
    }

    private async Task SelectOffering(Guid offeringId)
    {
        SelectedOfferingId = offeringId;
        await TryScrollToCalendar();
    }

    private async Task SelectBarber(Guid barberId)
    {
        SelectedBarberId = barberId;
        await TryScrollToCalendar();
    }

    private async Task TryScrollToCalendar()
    {
        if (_selectedBarberId != Guid.Empty && _selectedOfferingId != Guid.Empty)
        {
            await InvokeAsync(StateHasChanged);
            await ScrollService.ScrollToElementAsync("calendar-table");
        }
    }

    private async Task TryScrollToSummary()
    {
        if (selectedSlot != null)
        {
            await InvokeAsync(StateHasChanged);
            await ScrollService.ScrollToElementAsync("booking-summary");
        }
    }
    private void UpdateDisabledState()
    {
        var thisWeekStart = DateTime.Today.StartOfWeek(DayOfWeek.Monday);
        IsDisabled = weekStart <= thisWeekStart;
    }

    private async Task LoadSlots()
    {
        timeslots = await TimeslotService.GetWeeklySlotsAsync(weekStart);
        selectedSlot = null;
        UpdateDisabledState();
        StateHasChanged();
    }

    private void GenerateTimeRanges()
    {
        timeRanges.Clear();
        var startTime = weekStart.AddHours(9);
        var endTime = weekStart.AddHours(17);

        while (startTime < endTime)
        {
            timeRanges.Add(startTime);
            startTime = startTime.AddMinutes(30);
        }
    }

    private async Task PrevWeek()
    {
        weekStart = weekStart.AddDays(-7);
        await LoadSlots();
    }

    private async Task NextWeek()
    {
        weekStart = weekStart.AddDays(7);
        await LoadSlots();
    }

    private async Task SelectSlot(TimeslotDto timeslot)
    {
        selectedSlot = timeslot;
        appointment.BarberId = timeslot.BarberId;
        appointment.AppointmentDateTime = timeslot.Start;
        appointment.DurationMinutes = timeslot.Duration;

        var barber = barbers?.FirstOrDefault(b => b.Id == timeslot.BarberId);
        appointment.BarberPositionId = barber?.PositionId ?? 0;

        await TryScrollToSummary();
    }

    public async Task HandleValidSubmit()
    {
        IsSubmitting = true;

        if (selectedSlot == null)
            return;

        appointment.DurationMinutes = selectedSlot.Duration;

        var barber = barbers?.FirstOrDefault(b => b.Id == appointment.BarberId);
        var offering = offerings?.FirstOrDefault(o => o.Id == appointment.OfferingId);

        appointment.BarberName = barber?.Name ?? "";
        appointment.OfferingName = offering?.Name ?? "";

        var savedAppointment = await AppointmentsService.CreateAppointmentAsync(appointment);

        if (savedAppointment == null)
        {
            IsSubmitting = false;
            return;
        }

        Navigation.NavigateTo($"/booking-confirmed/{savedAppointment?.Id}");
    }
}
