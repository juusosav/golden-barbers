@using GoldenBarbers.Client.Services
@using System.Threading.Tasks
@using Shared.DTOs.Admin.Barbers

@inject AdminBarberApiService BarberApiService
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> L

@page "/admin/manage-barbers/create-barber"

<h3>@L["CreateBarber_Title"]</h3>
<br />

<EditForm Model="barber" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="admin-form">
        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormBarberName"] </label>
            <br />
            <InputText @bind-Value="@barber.Name" />
        </div>

        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormBarberPositionName"] </label>
            <br />
            <InputText @bind-Value="barber.PositionName" />
        </div>

        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormBarberPositionIdentifier"] </label>
            <br />
            <InputNumber @bind-Value="@barber.PositionId" />
        </div>

        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormPortrait"] </label>
            <br />
            @if (imagePreviewSrc != null)
            {
                <img src="@imagePreviewSrc" style="max-height: 100px;" />
                <br />
            }

            <InputFile OnChange="HandleFileSelected" accept="image/*" />
        </div>

        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormSalary"] </label>
            <br />
            <InputNumber @bind-Value="barber.Salary" />
        </div>

        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormStartingDate"] </label>
            <br />
            <InputDate @bind-Value="barber.StartDate" />
        </div>

        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormEmail"] </label>
            <br />
            <InputText @bind-Value="@barber.PersonalEmail" />
        </div>

        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormPhone"] </label>
            <br />
            <InputText @bind-Value="@barber.PersonalPhone" />
        </div>

        <div class="admin-form-item">
            <label>@L["Create_EditBarber_FormAddress"] </label>
            <br />
            <InputText @bind-Value="@barber.PersonalAddress" />
        </div>

        <br />
        <button class="btn btn-outline-dark" type="submit" disabled=@IsSubmitting>@L["Create_EditBarber_ConfirmButton"]</button>
    </div>
</EditForm>


@code {
    private AdminBarberDto barber { get; set; } = new AdminBarberDto();

    private IBrowserFile? selectedFile;
    private string? imagePreviewSrc;

    private bool IsSubmitting { get; set; } = false;

    public async Task HandleValidSubmit()
    {
        IsSubmitting = true;

        var created = await BarberApiService.CreateBarberAsync(barber, selectedFile);

        if (created != null)
        {
            Navigation.NavigateTo("admin/manage-barbers");
        }

        IsSubmitting = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;

        if (selectedFile != null)
        {
            var imageStream = selectedFile.OpenReadStream();
            var buffer = new byte[imageStream.Length];
            await imageStream.ReadAsync(buffer);
            imagePreviewSrc = $"data:image/*;base64,{Convert.ToBase64String(buffer)}";
            StateHasChanged();
        }
    }
}
