@using GoldenBarbers.Client.Services.Admin;
@using Shared.DTOs.Admin.Metrics;

<div class="dashboard-items">
    @if (RevenueChangeCount == null)
    {
        <button class="custom-dashboard-button btn btn-lg btn-outline-dark m-2">Data Not Yet Available</button>
    }
    else
    {
        @if (AppointmentsChangeCount >= 0)
        {
            <button style="font-size: 20px;" class="custom-dashboard-button btn btn-lg btn-outline-dark m-2">Appointment Count Change From Last Month: <br />@AppointmentsChangeCount.Value.ToString("F1") %</button>
        }
        else if (AppointmentsChangeCount < 0)
        {
            <button style="font-size: 20px;" class="custom-dashboard-button btn btn-lg btn-outline-dark m-2">Appointment Count Change From Last Month: <br />@AppointmentsChangeCount.Value.ToString("F1") %</button>
        }


        @if (RevenueChangeCount >= 0)
        {
            <button style="font-size: 20px;" class="custom-dashboard-button btn btn-lg btn-outline-dark m-2">Revenue Change From Last Month: <br />@RevenueChangeCount.Value.ToString("F1") %</button>
        }
        else if (RevenueChangeCount < 0)
        {
            <button style="font-size: 20px;" class="custom-dashboard-button btn btn-lg btn-outline-dark m-2">Revenue Change From Last Month: <br />@RevenueChangeCount.Value.ToString("F1") %</button>
        }

    }
</div>


@code {
    [Parameter]
    public decimal? AppointmentsChangeCount { get; set; }
    [Parameter]
    public decimal? RevenueChangeCount { get; set; }

}
