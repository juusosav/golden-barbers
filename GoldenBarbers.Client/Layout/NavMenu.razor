@using Microsoft.Extensions.Localization
@using System.Globalization

@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> L
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<nav class="custom-nav">

    <a href="">
        <img class="main-logo" src="/images/golden_barbers_logo.png" alt="Golden Barbers Logo" />
    </a>

    <input type="checkbox" id="nav-toggle" class="navbar-toggler" />
    <label for="nav-toggle" class="hamburger">☰</label>

    <div class="nav-links">
        <NavLink class="custom-nav-item" href="" Match="NavLinkMatch.All">
            <span class="custom-nav-link" aria-hidden="true">@L["NavMenu_Home"]</span>
        </NavLink>
        <NavLink class="custom-nav-item" href="our-team" Match="NavLinkMatch.All">
            <span class="custom-nav-link" aria-hidden="true">@L["NavMenu_OurTeam"]</span>
        </NavLink>
        <NavLink class="custom-nav-item" href="book-appointment" Match="NavLinkMatch.All">
            <span class="custom-nav-link" aria-hidden="true">@L["NavMenu_BookAppointment"]</span>
        </NavLink>
        <div class="dropdown">
            <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                🌐 @L["NavMenu_Language"]
            </button>

            <ul class="dropdown-menu">
                <li>
                    <button class="dropdown-item" @onclick='() => ChangeLanguage("en")'>
                        🇬🇧 English
                    </button>
                </li>
                <li>
                    <button class="dropdown-item" @onclick='() => ChangeLanguage("fi")'>
                        🇫🇮 Suomi
                    </button>
                </li>
            </ul>
        </div>
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await JS.InvokeVoidAsync("navHelper.closeMenu");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    async Task ChangeLanguage(string culture)
    {
        await JS.InvokeVoidAsync("cultureManager.set", culture);
    }
}

