@inherits LayoutComponentBase

@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<div class="admin-page">

    <div class="mobile-topbar">
        <div class="mobile-topbar-row">
            <span class="admin-brand">Golden Barbers</span>
            <button class="admin-hamburger" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#nav-toggle">
                ☰
            </button>
        </div>
        <div id="nav-toggle" class="collapse">
            <AdminNavMenu />
        </div>
    </div>

    <!-- Desktop sidebar -->
    <div class="sidebar">
        <span class="admin-brand">Golden Barbers</span>
        <AdminNavMenu />
    </div>

    <div class="main-content">

        <article class="content px-4">
            @Body
        </article>
    </div>

</div>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await JS.InvokeVoidAsync("navHelper.closeMenu");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}